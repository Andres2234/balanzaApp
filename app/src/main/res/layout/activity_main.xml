<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Balanza BT"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="bazsoft.sosnegocios.com"
        android:textSize="12sp"
        android:textColor="#888888"
        android:gravity="center"
        android:paddingBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dispositivos Bluetooth emparejados:"
        android:textSize="16sp"
        android:textColor="#333333"
        android:paddingBottom="8dp"/>

    <ListView
        android:id="@+id/listDispositivos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"/>

    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecciona tu balanza y presiona Iniciar"
        android:textSize="14sp"
        android:textColor="#555555"
        android:gravity="center"
        android:padding="12dp"/>

    <Button
        android:id="@+id/btnIniciar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶  INICIAR SERVICIO"
        android:textSize="16sp"
        android:backgroundTint="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnDetener"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="■  DETENER SERVICIO"
        android:textSize="16sp"
        android:backgroundTint="#B71C1C"
        android:textColor="#FFFFFF"/>

</LinearLayout>

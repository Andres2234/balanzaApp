<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F0F4FF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Balanza BT"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <LinearLayout
        android:id="@+id/layoutPeso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PESO EN TIEMPO REAL"
            android:textSize="11sp"
            android:textColor="#9E9E9E"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvPeso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- kg"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvEstadoPeso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esperando..."
            android:textSize="18sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#BDBDBD"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DATOS CRUDOS BLUETOOTH:"
            android:textSize="10sp"
            android:textColor="#9E9E9E"
            android:paddingTop="12dp"/>

        <TextView
            android:id="@+id/tvRaw"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(esperando datos...)"
            android:textSize="12sp"
            android:textColor="#333333"
            android:fontFamily="monospace"
            android:background="#F5F5F5"
            android:padding="8dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dispositivos Bluetooth emparejados:"
        android:textSize="13sp"
        android:textColor="#424242"
        android:paddingBottom="4dp"/>

    <ListView
        android:id="@+id/listDispositivos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"/>

    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecciona tu balanza y presiona Iniciar"
        android:textSize="13sp"
        android:textColor="#555555"
        android:gravity="center"
        android:padding="8dp"/>

    <Button
        android:id="@+id/btnIniciar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="INICIAR SERVICIO"
        android:backgroundTint="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnDetener"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="DETENER"
        android:backgroundTint="#B71C1C"
        android:textColor="#FFFFFF"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Nombre de la marca:" android:textSize="13sp" android:textStyle="bold"/>
        <EditText android:id="@+id/etNombre" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Ej: Balanza Ohaus"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Carácter terminador:" android:textSize="13sp" android:textStyle="bold"
            android:layout_marginTop="10dp"/>
        <EditText android:id="@+id/etTerminador" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Ej: = o \n o \r\n"
            android:fontFamily="monospace"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="= para balanza original, \n para balanza ST/US"
            android:textSize="11sp" android:textColor="#888888"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Expresión Regular (Regex):" android:textSize="13sp"
            android:textStyle="bold" android:layout_marginTop="10dp"/>
        <EditText android:id="@+id/etRegex" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Ej: ^(.{8})(.)$"
            android:fontFamily="monospace" android:inputType="text"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="10dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Grupo del Peso:" android:textSize="13sp" android:textStyle="bold"/>
                <EditText android:id="@+id/etGrupoPeso" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="1"
                    android:inputType="number" android:fontFamily="monospace"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Grupo del Estado:" android:textSize="13sp" android:textStyle="bold"/>
                <EditText android:id="@+id/etGrupoEstado" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="2"
                    android:inputType="number" android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="10dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Código Estable:" android:textSize="13sp" android:textStyle="bold"/>
                <EditText android:id="@+id/etEstable" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="B o ST"
                    android:fontFamily="monospace"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Código Inestable:" android:textSize="13sp" android:textStyle="bold"/>
                <EditText android:id="@+id/etInestable" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="@ o US"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="10dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Cero Estable (opcional):" android:textSize="12sp"/>
                <EditText android:id="@+id/etCeroEstable" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="C"
                    android:fontFamily="monospace"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Cero Inestable (opcional):" android:textSize="12sp"/>
                <EditText android:id="@+id/etCeroInestable" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="A"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Ayuda -->
        <TextView android:id="@+id/tvAyudaRegex"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:padding="8dp"
            android:background="#F5F5F5" android:textSize="11sp"
            android:textColor="#555555" android:fontFamily="monospace"/>

    </LinearLayout>
</ScrollView>
